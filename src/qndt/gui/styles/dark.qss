/* Quasar dark scientific-instrument theme (CLAUDE.md §7.1).
 *
 * Palette:
 *   bg-darkest      #0d1117   window background
 *   bg-dark         #161b22   panel / dock background
 *   bg-medium       #1f2630   input fields, table rows
 *   bg-light        #2a3441   hover / raised surfaces
 *   border          #30363d   hairline borders
 *   text-primary    #c9d1d9   primary text
 *   text-secondary  #8b949e   secondary / disabled text
 *   accent-primary  #58a6ff   focus, links, primary actions
 *   accent-success  #3fb950   nominal / healthy state
 *   accent-warning  #d29922   degraded state
 *   accent-danger   #f85149   fault / destructive action
 */

/* ---------------------------------------------------------------- */
/* Base surfaces                                                     */
/* ---------------------------------------------------------------- */

QMainWindow, QDialog, QWidget {
    background-color: #0d1117;
    color: #c9d1d9;
    font-family: "Segoe UI", "Helvetica Neue", sans-serif;
    font-size: 12px;
}

/* ---------------------------------------------------------------- */
/* Menu bar / menus                                                   */
/* ---------------------------------------------------------------- */

QMenuBar {
    background-color: #161b22;
    color: #c9d1d9;
    border-bottom: 1px solid #30363d;
    padding: 2px;
}

QMenuBar::item {
    background: transparent;
    padding: 4px 10px;
    border-radius: 3px;
}

QMenuBar::item:selected {
    background-color: #2a3441;
}

QMenu {
    background-color: #161b22;
    color: #c9d1d9;
    border: 1px solid #30363d;
    padding: 4px;
}

QMenu::item {
    padding: 5px 24px 5px 12px;
    border-radius: 3px;
}

QMenu::item:selected {
    background-color: #2a3441;
}

QMenu::separator {
    height: 1px;
    background-color: #30363d;
    margin: 4px 6px;
}

/* ---------------------------------------------------------------- */
/* Dock widgets                                                       */
/* ---------------------------------------------------------------- */

QDockWidget {
    background-color: #161b22;
    color: #c9d1d9;
    titlebar-close-icon: none;
    titlebar-normal-icon: none;
    border: 1px solid #30363d;
}

QDockWidget::title {
    background-color: #1f2630;
    padding: 6px 8px;
    border-bottom: 1px solid #30363d;
    font-weight: 600;
}

/* ---------------------------------------------------------------- */
/* Tabs                                                                */
/* ---------------------------------------------------------------- */

QTabWidget::pane {
    border: 1px solid #30363d;
    background-color: #161b22;
}

QTabBar::tab {
    background-color: #1f2630;
    color: #8b949e;
    padding: 6px 14px;
    border: 1px solid #30363d;
    border-bottom: none;
}

QTabBar::tab:selected {
    background-color: #161b22;
    color: #c9d1d9;
    border-bottom: 2px solid #58a6ff;
}

QTabBar::tab:hover {
    color: #c9d1d9;
}

/* ---------------------------------------------------------------- */
/* Buttons                                                             */
/* ---------------------------------------------------------------- */

QPushButton {
    background-color: #1f2630;
    color: #c9d1d9;
    border: 1px solid #30363d;
    border-radius: 4px;
    padding: 6px 14px;
}

QPushButton:hover {
    background-color: #2a3441;
    border-color: #58a6ff;
}

QPushButton:pressed {
    background-color: #161b22;
}

QPushButton:disabled {
    color: #8b949e;
    background-color: #161b22;
}

QPushButton#primary {
    background-color: #58a6ff;
    color: #0d1117;
    border: none;
    font-weight: 600;
}

QPushButton#primary:hover {
    background-color: #79b8ff;
}

QPushButton#danger {
    background-color: #f85149;
    color: #0d1117;
    border: none;
    font-weight: 600;
}

QPushButton#danger:hover {
    background-color: #ff7b72;
}

/* ---------------------------------------------------------------- */
/* Inputs                                                             */
/* ---------------------------------------------------------------- */

QLineEdit, QSpinBox, QDoubleSpinBox, QComboBox {
    background-color: #1f2630;
    color: #c9d1d9;
    border: 1px solid #30363d;
    border-radius: 4px;
    padding: 4px 6px;
    selection-background-color: #58a6ff;
}

QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus, QComboBox:focus {
    border-color: #58a6ff;
}

QLineEdit:disabled, QSpinBox:disabled, QDoubleSpinBox:disabled, QComboBox:disabled {
    color: #8b949e;
    background-color: #161b22;
}

QComboBox::drop-down {
    border: none;
    width: 18px;
}

QComboBox QAbstractItemView {
    background-color: #1f2630;
    color: #c9d1d9;
    border: 1px solid #30363d;
    selection-background-color: #2a3441;
}

/* ---------------------------------------------------------------- */
/* Tables / trees / lists                                             */
/* ---------------------------------------------------------------- */

QTableWidget, QTreeWidget, QListWidget {
    background-color: #161b22;
    color: #c9d1d9;
    border: 1px solid #30363d;
    gridline-color: #30363d;
    alternate-background-color: #1f2630;
}

QTableWidget::item, QTreeWidget::item, QListWidget::item {
    padding: 3px;
}

QTableWidget::item:selected, QTreeWidget::item:selected, QListWidget::item:selected {
    background-color: #2a3441;
    color: #c9d1d9;
}

QHeaderView::section {
    background-color: #1f2630;
    color: #8b949e;
    padding: 5px;
    border: none;
    border-right: 1px solid #30363d;
    border-bottom: 1px solid #30363d;
    font-weight: 600;
}

/* ---------------------------------------------------------------- */
/* Scrollbars                                                         */
/* ---------------------------------------------------------------- */

QScrollBar:vertical {
    background-color: #161b22;
    width: 12px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background-color: #30363d;
    border-radius: 5px;
    min-height: 24px;
}

QScrollBar::handle:vertical:hover {
    background-color: #58a6ff;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

QScrollBar:horizontal {
    background-color: #161b22;
    height: 12px;
    margin: 0;
}

QScrollBar::handle:horizontal {
    background-color: #30363d;
    border-radius: 5px;
    min-width: 24px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #58a6ff;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
}

/* ---------------------------------------------------------------- */
/* Labels / group boxes                                               */
/* ---------------------------------------------------------------- */

QLabel#section_header {
    color: #58a6ff;
    font-weight: 700;
    font-size: 13px;
    padding: 4px 0;
    border-bottom: 1px solid #30363d;
}

QGroupBox {
    border: 1px solid #30363d;
    border-radius: 4px;
    margin-top: 10px;
    padding-top: 12px;
    font-weight: 600;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 4px;
    color: #8b949e;
}

/* ---------------------------------------------------------------- */
/* Status bar                                                         */
/* ---------------------------------------------------------------- */

QStatusBar {
    background-color: #161b22;
    color: #8b949e;
    border-top: 1px solid #30363d;
}

QStatusBar::item {
    border: none;
}

/* ---------------------------------------------------------------- */
/* Splitters                                                          */
/* ---------------------------------------------------------------- */

QSplitter::handle {
    background-color: #30363d;
}

QSplitter::handle:hover {
    background-color: #58a6ff;
}

/* ---------------------------------------------------------------- */
/* Tooltips                                                            */
/* ---------------------------------------------------------------- */

QToolTip {
    background-color: #1f2630;
    color: #c9d1d9;
    border: 1px solid #30363d;
    padding: 4px 6px;
}

/* ---------------------------------------------------------------- */
/* Node palette sidebar                                              */
/* ---------------------------------------------------------------- */

QWidget#node_palette {
    background-color: #161b22;
    border-right: 1px solid #30363d;
}

QLabel#palette_header {
    color: #8b949e;
    font-size: 10px;
    font-weight: 600;
    padding-bottom: 4px;
    border-bottom: 1px solid #30363d;
}

QPushButton#palette_button {
    background: transparent;
    border: none;
}

/* ---------------------------------------------------------------- */
/* Canvas toolbar strip                                              */
/* ---------------------------------------------------------------- */

QWidget#canvas_toolbar {
    background-color: #161b22;
    border-bottom: 1px solid #30363d;
    min-height: 30px;
    max-height: 30px;
}

QPushButton#canvas_toolbar_btn {
    background-color: #1f2630;
    color: #c9d1d9;
    border: 1px solid #30363d;
    border-radius: 3px;
    padding: 2px 10px;
    font-size: 11px;
}

QPushButton#canvas_toolbar_btn:hover {
    background-color: #2a3441;
    border-color: #58a6ff;
}

QPushButton#canvas_toolbar_btn:pressed {
    background-color: #161b22;
}

QWidget#canvas_toolbar_sep {
    background-color: #30363d;
    margin: 4px 2px;
}
